---
import Layout from '../layouts/Layout.astro';
import HeroSection from "../components/presentation/header"
import ServicesSection from "../components/presentation/feature"
import EquiposSection from "../components/presentation/equipos"
import NosotrosSection from "../components/presentation/nosotros"
import ContactoSection from "../components/presentation/contacto"
import Footer from "../components/presentation/footerFree"
---

<Layout title="Inicio" metaDescription="CR Soluciones Industriales — Diseño, fabricación y reparación de piezas industriales. Asesoría, construcción, mantenimiento por outsourcing y montajes para la industria del caucho y plástico.">
	<main>
    <HeroSection client:only="react" />
    <ServicesSection client:only="react" />
    <EquiposSection client:only="react" />
    <NosotrosSection client:only="react" />
    <ContactoSection client:only="react" />
    <Footer client:only="react" />
  </main>
</Layout>
