---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Página no encontrada">
  <main class="flex min-h-screen items-center justify-center bg-blue-gray-50 px-6">
    <div class="text-center">
      <p class="text-6xl font-bold text-amber-600 mb-4">404</p>
      <h1 class="text-3xl font-bold text-blue-gray-900 mb-4">Página no encontrada</h1>
      <p class="text-lg text-gray-600 mb-8">Lo sentimos, la página que buscas no existe.</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="/"
          class="rounded-lg bg-blue-gray-900 px-6 py-3 text-sm font-medium text-white hover:bg-blue-gray-800 transition-colors"
        >
          Volver al inicio
        </a>
        <a
          href="https://wa.me/573113608491"
          target="_blank"
          rel="noreferrer"
          class="rounded-lg bg-green-600 px-6 py-3 text-sm font-medium text-white hover:bg-green-700 transition-colors flex items-center gap-2"
        >
          <i class="fab fa-whatsapp text-lg"></i>
          Contactar por WhatsApp
        </a>
      </div>
    </div>
  </main>
</Layout>
