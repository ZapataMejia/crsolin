---
export interface Props {
  title: string;
  metaDescription?: string;
}

const { title, metaDescription = "Diseño, fabricación y reparación de piezas industriales. Asesoría, construcción, mantenimiento por outsourcing y montajes." } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <title>{title} | CR Soluciones Industriales</title>
    <meta name="description" content={metaDescription} />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={`${title} | CR Soluciones Industriales`} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://crsolin.com" />
    <link rel="canonical" href="https://crsolin.com" />
  </head>
  <body class="overflow-x-hidden font-sans antialiased">
    <slot />
  </body>
</html>
<style is:global>
  body {
    font-family: 'Inter', sans-serif;
  }
</style>
